{
  "name": "meme-generator",
  "version": "0.0.1",
  "description": "用于制作趣味图片的Node.js API服务",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "SERVER_PORT=8080 node dist/app.js",
    "dev": "ts-node src/app.ts",
    "dev:api": "ts-node src/app.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "meme",
    "image",
    "generator",
    "express",
    "api"
  ],
  "author": "祁筱欣 <qixiaoxin@stu.sqxy.edu.cn>",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaomizhoubaobei/meme-generator.git"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "canvas": "^3.2.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "file-type": "^18.7.0",
    "mime-types": "^2.1.35",
    "multer": "^2.0.1",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.1",
    "toml": "^3.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
