# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Images and binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Lock files
package-lock.json text eol=lf
yarn.lock text eol=lf